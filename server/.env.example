# LLM Provider — claude | openai | gemini
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...           # optional, required when LLM_PROVIDER=openai

# Migration defaults
DEFAULT_TARGET_CLOUD=aws        # aws | azure | gcp
ENABLE_MULTI_AGENT=true
ESTIMATION_MODEL=parametric     # parametric | analogous
MAX_APPS_PER_RUN=50

# Report output
REPORT_FORMAT=json              # json | markdown | docx | pdf
REPORT_OUTPUT_DIR=./outputs

# Upload limits
MAX_UPLOAD_SIZE_MB=25

# Databases (SQLite defaults; swap to postgres:// for production)
POLICIES_DB_URL=sqlite+aiosqlite:///./data/policies.sqlite
AUDIT_DB_URL=sqlite+aiosqlite:///./data/audit.sqlite
